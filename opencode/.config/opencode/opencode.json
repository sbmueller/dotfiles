{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "allow",
      "rm *": "deny",
      "mv *": "ask"
    },
    "edit": "ask",
    "mcp": "ask",
    "websearch": "ask",
    "webfetch": "ask"
  },
  "mcp": {
    "basic-memory": {
      "type": "local",
      "command": ["uvx", "basic-memory", "mcp"],
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:GH_TOKEN}"
      }
    },
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    }
  },
  "plugin": ["opencode-cmux"]
}
